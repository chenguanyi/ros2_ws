# Copy this file to scripts/remote.env and edit it for your board.
# scripts/remote.env is private local configuration and should not be committed.

# SSH target
REMOTE_USER="orangepi"
REMOTE_HOST="10.249.41.19"
REMOTE_PORT="22"

# Remote source mirror. For ROS2, keep this pointed at the src directory or a single
# package under src; never set this to /, ~, /home/<user>, or the workspace root.
REMOTE_SRC_DIR="/home/orangepi/ros2_ws/src"

# Working directory used when running remote commands. For ROS2 this should be the
# workspace root, not the src directory.
REMOTE_WORK_DIR="/home/orangepi/ros2_ws"

# Set to 1 only after the initial remote-to-local pull has completed and local is
# the canonical source. Real local-to-remote pushes are blocked while this is 0.
LOCAL_SOURCE_IS_CANONICAL="0"

# Commands executed on the remote board from REMOTE_WORK_DIR.
# Adjust the ROS distro and run command for the real target environment.
REMOTE_BUILD_CMD="source /opt/ros/humble/setup.bash && colcon build --symlink-install"
REMOTE_RUN_CMD="source /opt/ros/humble/setup.bash && source install/setup.bash && ros2 pkg list"

# Optional extra rsync exclude patterns, separated by spaces.
# Example: RSYNC_EXTRA_EXCLUDES=".vscode/ large-data/"
RSYNC_EXTRA_EXCLUDES=""

# Optional extra ssh options, separated by spaces.
# Example: SSH_EXTRA_OPTS="-i ~/.ssh/board_ed25519"
SSH_EXTRA_OPTS=""
